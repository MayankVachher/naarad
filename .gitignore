# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments + uv cache (the systemd unit redirects uv's cache
# into the install dir to keep its sandbox tight; we don't want it tracked).
.venv
.venv-*
.uv-cache/

# Secrets — config.json holds tokens, API keys, chat_id
config.json
.env

# Local SQLite state
*.db
*.db-journal
*.db-wal
*.db-shm

# Runtime logs
logs/

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
